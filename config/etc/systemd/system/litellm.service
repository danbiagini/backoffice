[Unit]
Description=LiteLLM proxy (Vertex via instance SA)
After=network-online.target
Wants=network-online.target

[Service]
User=hermes
ExecStart=/home/hermes/.local/bin/litellm --config /home/hermes/litellm/config.yaml --port 4000 --host 127.0.0.1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
